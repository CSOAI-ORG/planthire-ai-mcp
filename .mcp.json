{
  "name": "planthire-ai-mcp",
  "description": "AI-powered planthire ai MCP server for agents. Supports search equipment, get rental quote, check availability. By MEOK AI Labs.",
  "version": "1.0.0",
  "tools": [
    {
      "name": "search_equipment",
      "description": "Search the construction equipment catalog.",
      "parameters": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "max_weight_tonnes": {
            "type": "number"
          },
          "min_dig_depth_m": {
            "type": "number"
          },
          "max_daily_rate": {
            "type": "number"
          },
          "requires_licence": {
            "type": "boolean"
          }
        },
        "required": []
      }
    },
    {
      "name": "get_rental_quote",
      "description": "Calculate rental pricing for equipment.",
      "parameters": {
        "type": "object",
        "properties": {
          "equipment_id": {
            "type": "string"
          },
          "duration_days": {
            "type": "integer"
          },
          "include_insurance": {
            "type": "boolean"
          },
          "include_fuel": {
            "type": "boolean"
          },
          "operator_required": {
            "type": "boolean"
          }
        },
        "required": [
          "equipment_id",
          "duration_days"
        ]
      }
    },
    {
      "name": "check_availability",
      "description": "Check equipment availability for a date range.",
      "parameters": {
        "type": "object",
        "properties": {
          "equipment_id": {
            "type": "string"
          },
          "start_date": {
            "type": "string"
          },
          "end_date": {
            "type": "string"
          },
          "depot": {
            "type": "string"
          }
        },
        "required": [
          "equipment_id",
          "start_date",
          "end_date"
        ]
      }
    },
    {
      "name": "create_booking",
      "description": "Create an equipment booking.",
      "parameters": {
        "type": "object",
        "properties": {
          "equipment_id": {
            "type": "string"
          },
          "start_date": {
            "type": "string"
          },
          "end_date": {
            "type": "string"
          },
          "depot": {
            "type": "string"
          },
          "customer_name": {
            "type": "string"
          },
          "customer_email": {
            "type": "string"
          },
          "customer_phone": {
            "type": "string"
          },
          "include_insurance": {
            "type": "boolean"
          },
          "operator_required": {
            "type": "boolean"
          },
          "delivery_address": {
            "type": "string"
          }
        },
        "required": [
          "equipment_id",
          "start_date",
          "end_date"
        ]
      }
    },
    {
      "name": "get_safety_checklist",
      "description": "Get pre-use safety inspection checklist for equipment type.",
      "parameters": {
        "type": "object",
        "properties": {
          "equipment_type": {
            "type": "string"
          }
        },
        "required": [
          "equipment_type"
        ]
      }
    },
    {
      "name": "calculate_transport",
      "description": "Estimate transport costs for equipment delivery/collection.",
      "parameters": {
        "type": "object",
        "properties": {
          "equipment_id": {
            "type": "string"
          },
          "distance_miles": {
            "type": "number"
          },
          "depot": {
            "type": "string"
          },
          "return_trip": {
            "type": "boolean"
          }
        },
        "required": [
          "equipment_id",
          "distance_miles"
        ]
      }
    }
  ]
}